{
  "manifest_version": 3,
  "name": "Get Back To Work",
  "version": "1.0.0",
  "description": "Redirects distraction sites to a reminder page so you stay focused.",
  "permissions": ["webNavigation", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Get Back To Work — Settings"
  }
}
